---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="page-wrapper">
    <!-- 800x600 BADGE (always visible) -->
    <div class="screen-badge">
      <img src="/gifs/HeHeartland3460buttonsConstructani.gif" alt="" />
      BEST VIEWED AT 800x600
      <img src="/gifs/HeHeartland3460buttonsConstructani.gif" alt="" />
    </div>

    <!-- MARQUEE HEADER -->
    <div class="marquee-container">
      <img
        src="/gifs/SunsetStripUnderground1358YellowandBlackconstructiontape.gif"
        alt="construction tape"
        class="tape"
      />
      <div class="marquee">
        <p>
          *** Welcome to My Awesome Web Site!!! *** Under Construction!!! ***
          Best Viewed in 800x600 *** Please Be Patient!!! ***
        </p>
      </div>
      <img
        src="/gifs/SunsetStripUnderground1358YellowandBlackconstructiontape.gif"
        alt="construction tape"
        class="tape"
      />
    </div>

    <!-- BLINKING TITLE -->
    <h1 class="blink">
      <img
        src="/gifs/HeHeartlandPrairie6170construct1.gif"
        alt=""
        class="inline-icon"
      />
      UNDER CONSTRUCTION
      <img
        src="/gifs/HeHeartlandPrairie6170construct1.gif"
        alt=""
        class="inline-icon"
      />
    </h1>

    <!-- DECORATION ROW -->
    <div class="deco-row">
      <img
        src="/gifs/CaCapeCanaveralStation2739IconsConstruction-SpinSign.gif"
        alt="spinning sign"
      />
      <img
        src="/gifs/HeHeartlandLake9817Construct3AVI.gif"
        alt="animated worker"
      />
      <img
        src="/gifs/HeHeartlandGarden5828constructionCaution4.gif"
        alt="caution sign"
      />
      <img src="/gifs/Chamber9602construction2.gif" alt="construction" />
      <img
        src="/gifs/CaCapeCanaveralStation2739IconsConstructionSign.gif"
        alt="sign"
      />
    </div>

    <div class="divider">
      <img src="/gifs/CaCapeCanaveral3537construct_line_2.gif" alt="line" />
    </div>

    <!-- MAIN CONTENT BOX -->
    <div class="content-box">
      <h2>Sorry for the Mess!</h2>
      <p>
        You have reached my corner of the <span class="www">World Wide Web</span
        >! Right now I am busy building my
        <span class="cool-text">REAL PORTFOLIO SITE</span>, so this temporary
        page will have to do. Please check back soon!
      </p>
      <p>
        In the meantime, feel free to look at all these totally radical animated
        GIFs I found. They are loading at 56k modem speeds, so please be
        patient!
      </p>
    </div>

    <div class="divider">
      <img src="/gifs/HeHeartland5384construct_line_bird.gif" alt="bird line" />
    </div>

    <!-- ========================================== -->
    <!--       WRITE YOUR SHORT MESSAGE HERE        -->
    <!-- ========================================== -->
    <div class="guestbook-box">
      <div class="guestbook-header">
        <img src="/gifs/AtAthensAcademy9957construction_line.gif" alt="" />
        <h3>:: A Special Message ::</h3>
        <img src="/gifs/AtAthensAcademy9957construction_line.gif" alt="" />
      </div>

      <div class="message-content">
        <p>
          Hey! If you are reading this from <strong>Apple</strong>, I do in fact
          own this site, I am Matt Campbell, and I do own the Odomtr app that
          can be found at <a href="https://odomtr.com" target="_blank"
            >Odomtr.com</a
          >. (That's another site I'm about to redo). If you're <strong
            >Matt, Billy, or Stephanie,</strong
          > Hi! Trust me, this is gonna look way better soon.
          <br />
          Thanks for stopping by! I'm currently building something awesome. Watch
          this space!
        </p>
      </div>

      <div class="deco-row small">
        <img src="/gifs/totokyoisland4174underconstruction.gif" alt="" />
        <img src="/gifs/HeHeartland3460buttonsConstructani.gif" alt="" />
        <img
          src="/gifs/ArArea51Station9771rulersconstructionconstruction_2.gif"
          alt=""
        />
      </div>
    </div>
    <!-- ========================================== -->

    <div class="divider">
      <img
        src="/gifs/HeHeartlandLane6362personalconstructionconst.gif"
        alt="line"
      />
    </div>

    <!-- EMAIL WEBMASTER -->
    <div class="email-box">
      <p>
        <img
          src="/gifs/HeHeartland3460buttonsConstructani.gif"
          alt=""
          class="inline-icon"
        />
        Questions? Comments? Suggestions?
        <a href="mailto:howdy@d6software.com">Email the Webmaster!</a>
        <img
          src="/gifs/HeHeartland3460buttonsConstructani.gif"
          alt=""
          class="inline-icon"
        />
      </p>
    </div>

    <!-- HIT COUNTER & BADGES -->
    <footer>
      <div class="hit-counter">
        You are visitor number:<br />
        <span class="counter-digits">0 0 0 0 4 2</span>
      </div>

      <div class="badge-row">
        <div class="badge">Best viewed in Netscape Navigator 4.0</div>
        <div class="badge">Made with Macromedia Dreamweaver</div>
        <div class="badge">Get Internet Explorer 5.0</div>
      </div>

      <div class="footer-deco">
        <img
          src="/gifs/SiSiliconValleyHaven8517Gif-Construction-Set.gif"
          alt="construction set"
        />
        <img
          src="/gifs/ReResearchTriangleThinktank5966graphicconstruct_line_1.gif"
          alt="line"
        />
        <img
          src="/gifs/MoMotorCityDowns6390construction.gif"
          alt="construction"
        />
      </div>

      <p class="copyright">
        &copy; 1998-2026 My D6Software. All rights reserved.<br />
        Last updated: <span id="last-updated">Loading...</span>
      </p>
    </footer>
  </div>
</Layout>

<style>
  .page-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px 10px;
    text-align: center;
  }

  /* SCREEN BADGE */
  .screen-badge {
    font-family: "Press Start 2P", monospace;
    font-size: 0.6rem;
    color: #00ff00;
    background: #000;
    border: 3px outset #c0c0c0;
    padding: 6px 12px;
    display: inline-block;
    margin-bottom: 10px;
  }
  .screen-badge img {
    height: 1em;
    vertical-align: middle;
    image-rendering: pixelated;
  }

  /* MARQUEE */
  .marquee-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
    border: 4px ridge #808080;
    background: #000;
    padding: 5px;
  }
  .tape {
    height: 40px;
    image-rendering: pixelated;
  }
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    background: #000080;
    color: #ffff00;
    font-family: "Press Start 2P", monospace;
    font-size: 0.65rem;
    padding: 8px 0;
    border: 2px inset #c0c0c0;
  }
  .marquee p {
    display: inline-block;
    padding-left: 100%;
    animation: marquee 12s linear infinite;
    margin: 0;
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  /* BLINK */
  .blink {
    font-family: "Press Start 2P", monospace;
    color: #ff0000;
    font-size: 1.8rem;
    animation: blink-animation 1s steps(2, start) infinite;
    text-shadow: 2px 2px #000000;
    margin: 20px 0;
  }
  @keyframes blink-animation {
    to {
      visibility: hidden;
    }
  }

  .inline-icon {
    vertical-align: middle;
    height: 1.2em;
    image-rendering: pixelated;
  }

  /* DECORATION ROWS */
  .deco-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
    margin: 15px 0;
  }
  .deco-row img {
    height: 80px;
    image-rendering: pixelated;
  }
  .deco-row.small img {
    height: 50px;
  }

  /* DIVIDERS */
  .divider {
    margin: 20px 0;
    overflow: hidden;
  }
  .divider img {
    height: 40px;
    width: 100%;
    object-fit: contain;
    image-rendering: pixelated;
  }

  /* CONTENT BOX */
  .content-box {
    border: 5px groove #c0c0c0;
    background: #111111;
    padding: 20px;
    margin: 20px 0;
    box-shadow: 5px 5px 0px #333333;
  }
  .content-box h2 {
    color: #00ff00;
    font-family: "VT323", monospace;
    font-size: 2.8rem;
    margin-top: 0;
    text-decoration: underline wavy #ff00ff;
  }
  .content-box p {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #e0e0e0;
  }
  .www {
    color: #00ffff;
    text-decoration: underline;
    font-weight: bold;
  }
  .cool-text {
    color: #ff00ff;
    font-weight: bold;
    text-transform: uppercase;
    text-shadow: 1px 1px #ffffff;
  }

  /* GUESTBOOK BOX */
  .guestbook-box {
    border: 4px double #ffff00;
    background: #000044;
    padding: 15px;
    margin: 30px 0;
  }
  .guestbook-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 15px;
    flex-wrap: wrap;
  }
  .guestbook-header img {
    height: 20px;
    image-rendering: pixelated;
  }
  .guestbook-header h3 {
    color: #00ffff;
    font-family: "VT323", monospace;
    font-size: 2.2rem;
    margin: 0;
  }
  .message-content {
    background: #ffffff;
    color: #000000;
    border: 3px inset #c0c0c0;
    padding: 15px;
    font-family: "Courier New", Courier, monospace;
    font-size: 1rem;
    text-align: left;
    min-height: 80px;
  }
  .message-content p {
    margin: 0;
    line-height: 1.5;
  }

  /* EMAIL BOX */
  .email-box {
    margin: 20px 0;
    font-size: 1.1rem;
  }

  /* FOOTER */
  footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 3px dashed #555555;
  }
  .hit-counter {
    font-family: "Courier New", Courier, monospace;
    font-size: 1.5rem;
    margin-bottom: 20px;
  }
  .counter-digits {
    display: inline-block;
    background: #000000;
    color: #00ff00;
    padding: 5px 10px;
    border: 2px inset #555555;
    font-family: "VT323", monospace;
    font-size: 2.2rem;
    letter-spacing: 6px;
  }
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .badge {
    background: #c0c0c0;
    color: #000000;
    padding: 5px 10px;
    border: 2px outset #ffffff;
    font-size: 0.85rem;
    font-weight: bold;
    font-family: sans-serif;
  }
  .footer-deco {
    margin: 20px 0;
  }
  .footer-deco img {
    height: 60px;
    image-rendering: pixelated;
    margin: 0 10px;
  }
  .copyright {
    color: #666666;
    font-size: 0.85rem;
    margin-top: 20px;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var now = new Date();
    var el = document.getElementById("last-updated");
    if (el) {
      el.textContent =
        now.toLocaleDateString() + " " + now.toLocaleTimeString();
    }
  });
</script>
